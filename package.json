{
  "name": "threejs-edit",
  "version": "1.0.0",
  "description": "Advanced 3D Editor with modular architecture and comprehensive selection system",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node src/tests/runSimpleTests.js",
    "test:validation": "node src/tests/validateModularSystem.js",
    "test:report": "node src/tests/ModularSystemReport.js",
    "test:all": "npm run test && npm run test:validation && npm run test:report",
    "test:coverage": "c8 node src/tests/runSimpleTests.js",
    "build": "rollup -c",
    "build:dev": "rollup -c --watch",
    "build:prod": "rollup -c --environment NODE_ENV:production",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "docs": "jsdoc -c jsdoc.json",
    "serve": "http-server dist -p 8080 -o",
    "demo": "node demo/demo.js",
    "benchmark": "node benchmark/benchmark.js",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run clean && npm run build && npm run test:all"
  },
  "keywords": [
    "3d",
    "editor",
    "threejs",
    "webgl",
    "geometry",
    "mesh",
    "selection",
    "scene",
    "materials",
    "uv",
    "undo",
    "redo"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/threejs-edit.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/threejs-edit/issues"
  },
  "homepage": "https://github.com/yourusername/threejs-edit#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^27.4.0",
    "eslint-plugin-prettier": "^5.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-livereload": "^2.0.0",
    "rollup-plugin-serve": "^2.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/tests/**/*.js",
      "!src/docs/**/*.js",
      "!src/demo/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/src/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setup.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true,
      "node": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
